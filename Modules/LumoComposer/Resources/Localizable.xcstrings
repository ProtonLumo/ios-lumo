    "By using Lumo, you agree to our [Terms](%@) and [Privacy Policy](%@)." : {
      "comment" : "Terms and privacy policy agreement text with clickable links. The text uses Markdown format with embedded URLs that should not be translated.",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Používáním aplikace Lumo souhlasíte s našimi [Podmínkami](%1$@) a [Zásadami ochrany osobních údajů](%2$@)."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Durch das Nutzen von Lumo stimmst du unseren [Nutzungsbedingungen](%1$@) und [Datenschutzbestimmungen](%2$@) zu."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "By using Lumo, you agree to our [Terms](%1$@) and [Privacy Policy](%2$@)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Al usar Lumo, aceptas nuestras [Condiciones](%1$@) y nuestra [Política de privacidad](%2$@)."
