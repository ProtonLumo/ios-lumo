          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lumo a besoin d'accéder à l'appareil photo pour vous permettre de capturer et de joindre des photos à vos messages."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
