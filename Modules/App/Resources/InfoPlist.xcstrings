    "NSMicrophoneUsageDescription" : {
      "comment" : "Privacy - Microphone Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lumo vyžaduje přístup k mikrofonu, aby mohla aktivovat hlasové ovládání pro asistenci AI."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lumo benötigt Zugriff auf das Mikrofon, um die Spracheingabe für die KI-Unterstützung zu aktivieren"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Lumo needs microphone access to enable voice input for AI assistance."
          }
        },
