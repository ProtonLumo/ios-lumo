    "NSCameraUsageDescription" : {
      "comment" : "Privacy - Camera Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Lumo needs camera access to let you capture and attach photos to your messages."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lumo benötigt Kamerazugriff, damit du Fotos aufnehmen und an deine Nachrichten anhängen kannst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Lumo needs camera access to let you capture and attach photos to your messages."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lumo necesita acceso a la cámara para permitirle capturar y adjuntar fotos a sus mensajes."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
