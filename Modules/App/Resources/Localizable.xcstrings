    "permission.microphone.denied.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "K použití hlasového vstupu prosím povolte přístup k mikrofonu v nastavení svého zařízení."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um Spracheingabe zu verwenden, aktiviere bitte den Mikrofonzugriff in deinen Geräteeinstellungen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To use voice input, please enable microphone access in your device settings."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para usar la entrada de voz, activa el acceso al micrófono en los ajustes de tu dispositivo."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para usar la entrada de voz, active el acceso al micrófono en los ajustes de su dispositivo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pour utiliser la saisie vocale, veuillez activer l'accès au microphone dans les paramètres de votre appareil."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Per usare l'input vocale, attiva l'accesso al microfono nelle impostazioni del tuo dispositivo."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Om steminvoer te gebruiken, gelieve microfoontoegang in te schakelen in de instellingen van uw apparaat."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aby użyć wprowadzania głosowego, włącz dostęp do mikrofonu w ustawieniach Twojego urządzenia."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para usar a entrada de voz, ative o acesso ao microfone nas configurações do seu dispositivo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Чтобы использовать голосовой ввод, включите доступ к микрофону в настройках устройства."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ses girişini kullanmak için aygıt ayarlarınızdan mikrofona erişme izni verin."
          }
        }
      }
    },
