    "app.error.network.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Došlo k chybě sítě. Ujistěte se, prosím, že jste připojeni k internetu."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein Netzwerkfehler ist aufgetreten. Bitte stelle sicher, dass du mit dem Internet verbunden bist."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A network error occurred. Please ensure you are connected to the internet."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se ha producido un error de red. Asegúrate de tener conexión a internet."
