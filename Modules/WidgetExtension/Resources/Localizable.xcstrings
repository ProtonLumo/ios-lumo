    "widget.prompt.snacks.full": {
      "extractionState": "manual",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Navrhněte nějaké zdravé odpolední svačiny, které mi dodají energii bez následného propadu cukru."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schlag einige gesunde Nachmittagssnacks vor, die meine Energie steigern, ohne einen Zuckerschock zu verursachen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Suggest some healthy afternoon snacks that will boost my energy without a sugar crash."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sugiéreme algunos tentempiés saludables para la tarde que me den energía sin un bajón de azúcar."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Sugiérame algunos refrigerios saludables para la tarde que aumenten mi energía sin un bajón de azúcar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Suggère-moi des collations saines pour l'après-midi qui me donneront de l'énergie sans pic de glycémie."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Suggeriscimi alcuni snack pomeridiani sani che aumentino la mia energia e che non mi facciano venire un calo di zuccheri."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Stel enkele gezonde middagsnacks voor die mijn energie een boost geven zonder een suikerdip."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zaproponuj jakieś zdrowe popołudniowe przekąski, które dodadzą mi energii bez gwałtownego spadku cukru."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
