    "widget.prompt.particlePlayground.full": {
      "extractionState": "manual",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Co by se stalo, kdybych se mohl(a) zmenšit na subatomární velikost?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Was würde passieren, wenn ich auf subatomare Größe schrumpfen könnte?"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "What would happen if I could shrink down to subatomic size?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Qué pasaría si pudiera reducirme al tamaño subatómico?"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Qué pasaría si pudiera reducirme al tamaño subatómico?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Que se passerait-il si je pouvais rétrécir jusqu'à une taille subatomique ?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Cosa succederebbe se potessi rimpicciolirmi fino a una dimensione subatomica?"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wat zou er gebeuren als ik zou kunnen krimpen tot subatomaire grootte?"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Co by się stało, gdyby można było się skurczyć do rozmiarów subatomowych?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O que aconteceria se eu pudesse encolher para um tamanho subatômico?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Что произойдет, если я смогу уменьшиться до субатомного размера?"
