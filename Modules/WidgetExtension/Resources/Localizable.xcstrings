    "widget.prompt.timeManagement.full": {
      "extractionState": "manual",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Jak mohu dnes lépe hospodařit se svým časem, abych splnil své nejdůležitější úkoly?"
          }
        },
        "de": {
