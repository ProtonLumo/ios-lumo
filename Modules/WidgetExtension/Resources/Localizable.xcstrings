    "widget.prompt.cosmicPerspective.full": {
      "extractionState": "manual",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Sdílejte něco o vesmíru, co dává život do perspektivy."
          }
        },
