    "widget.prompt.perspectiveBroadening.full": {
      "extractionState": "manual",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Jak mohu aktivně vyhledávat a chápat názory odlišné od mých vlastních?"
          }
        },
        "de": {
