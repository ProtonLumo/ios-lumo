    "widget.prompt.criticalThinking.full": {
      "extractionState": "manual",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Naučte mě praktické dovednosti kritického myšlení, které mohu použít k lepšímu hodnocení informací."
